{
  "name": "dispatch",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "build:server": "npm run build -w packages/server",
    "build:web": "npm run build -w packages/web",
    "build:daemon": "npm run build -w packages/daemon",
    "build:mcp": "npm run build -w packages/mcp",
    "build:runner": "npm run build -w packages/runner",
    "build": "npm run build:server && npm run build:web && npm run build:daemon && npm run build:mcp && npm run build:runner",
    "db:generate": "npm run db:generate -w packages/server",
    "db:migrate": "npm run db:migrate -w packages/server"
  }
}
